    <title>Tatkal Doctor</title>
    <style>
        main {
            margin: 0 auto;
            padding: 2rem 1rem;
            line-height: 1.7
        }

        .hero {
            display: flex;
            gap: 2rem;
            align-items: flex-start
        }

        .hero .left {
            flex: 1
        }

        .hero .right {
            flex: 0 0 360px
        }

        .card {
            background: #f8f8f8;
            padding: 1.25rem;
            border-radius: 8px;
            margin: 1rem 0
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem
        }

        .feature {
            background: #fff;
            border: 1px solid #eee;
            padding: 1rem;
            border-radius: 8px
        }

        @media (max-width:900px) {
            .hero {
                flex-direction: column
            }

            .feature-grid {
                grid-template-columns: 1fr
            }
        }

        /* ensure register CTA stays in top-right of nav */
        nav .btn {
            position: absolute;
            right: 1rem;
            top: 18px
        }

        nav {
            position: relative
        }
    </style>
</head>

<body>
    <div class="container">
        <nav>
            <div class="nav__logo"><img src="{{ asset('uploads') }}/logo/logo.png" alt="logo" style="width: 60%;" />
            </div>
